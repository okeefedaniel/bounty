#!/usr/bin/env bash
# Pre-push hook: when requirements.txt is changing in any commit being pushed,
# verify the keel pin is reachable from a branch or tag on the keel remote.
# Bypass with SKIP_KEEL_PIN_CHECK=1 or `git push --no-verify`.

set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
checker="$repo_root/scripts/check-keel-pin.sh"
req_path="requirements.txt"

[[ -x "$checker" ]] || exit 0

zero="0000000000000000000000000000000000000000"
need_check=0

while read -r local_ref local_sha remote_ref remote_sha; do
  [[ -z "$local_sha" ]] && continue
  if [[ "$local_sha" = "$zero" ]]; then
    continue  # branch deletion
  fi
  if [[ "$remote_sha" = "$zero" ]]; then
    range="$local_sha"  # new branch — check the tip's requirements.txt
  else
    range="$remote_sha..$local_sha"
  fi
  # Did any commit in the push touch requirements.txt?
  if [[ "$range" == *..* ]]; then
    if git diff --name-only "$range" -- "$req_path" 2>/dev/null | grep -q .; then
      need_check=1
      break
    fi
  else
    # New branch: just check whether the file exists at the tip.
    if git cat-file -e "${range}:${req_path}" 2>/dev/null; then
      need_check=1
      break
    fi
  fi
done

if [[ "$need_check" -eq 0 ]]; then
  exit 0
fi

# Run the checker against the working-tree requirements.txt — that's what's
# committed at HEAD on this branch in practice. Falls through to exit 1 on
# failure, blocking the push. Use --no-verify or SKIP_KEEL_PIN_CHECK=1 to bypass.
"$checker" "$repo_root/$req_path"
