# Bounty Environment Variables
# Copy this file to .env and fill in values

# Django
DJANGO_SECRET_KEY=change-me-to-a-random-50-char-string
DJANGO_DEBUG=True
DEMO_MODE=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database — PostgreSQL everywhere (prod + CI + local dev). See keel/CLAUDE.md.
# Local one-time setup: brew services start postgresql@16 && createdb bounty_dev
DATABASE_URL=postgres:///bounty_dev

# Email
RESEND_API_KEY=
DEFAULT_FROM_EMAIL=DockLabs <info@docklabs.ai>

# Suite SSO via Keel (leave unset for standalone mode + direct Microsoft SSO)
# KEEL_OIDC_CLIENT_ID=
# KEEL_OIDC_CLIENT_SECRET=
# KEEL_OIDC_ISSUER=https://keel.docklabs.ai

# Microsoft Entra ID (Azure AD) — used when OIDC not configured
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# Suite-mode integrations (leave unset for standalone deploy)
# HELM_FEED_API_KEY=

# Grants.gov API (Simpler Grants.gov — free tier; get key at https://simpler.grants.gov)
# GRANTS_GOV_API_KEY=

# AI (opportunity scoring, match relevance)
# ANTHROPIC_API_KEY=

# Manifest (signing handoff — leave unset for standalone)
# MANIFEST_URL=
# MANIFEST_API_TOKEN=
# MANIFEST_WEBHOOK_SECRET=
